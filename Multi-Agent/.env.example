# Multi-Agent Research Assistant — environment file
# Copy to `.env` and fill in your OpenAI key.

# --- LLM ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.2

# --- Web search (DuckDuckGo, no API key) ---
DUCKDUCKGO_NUM_RESULTS=5
WEB_SEARCH_MAX_RETRIES=3

# --- Agent loop ---
# Default max critic iterations when the API caller doesn't pass one.
MAX_ITERATIONS_DEFAULT=3

# --- Logging ---
# Set to DEBUG to see httpx/openai chatter as well.
LOG_LEVEL=INFO

# --- Frontend → backend URL (optional override) ---
# MARA_API_URL=http://127.0.0.1:8000
