# NL-to-SQL Analyst — environment file
# Copy to `.env` (project root or backend/) and fill in your secrets.

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- MySQL (application credentials — READ-ONLY user, never root) ---
# For Docker Compose: leave MYSQL_HOST=mysql (the compose service name).
# For local dev outside Docker: MYSQL_HOST=localhost.
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DB=sakila
MYSQL_USER=mara_readonly
MYSQL_PASSWORD=changeme

# Docker Compose only — the root password the mysql container uses to bootstrap
# itself. The application never reads this; it only ever connects as MYSQL_USER.
MYSQL_ROOT_PASSWORD=changemeroot

# --- ChromaDB ---
# Local dev: ./chroma_data is fine. Docker: compose sets this to /data/chroma.
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=schema_index

# --- Agent knobs ---
RETRIEVAL_TOP_K=10
SQL_VALIDATION_MAX_RETRIES=1
SQL_EXECUTION_MAX_RETRIES=2
STATEMENT_TIMEOUT_MS=15000
RESULT_ROW_CAP=1000

# --- Logging ---
# Set to DEBUG to see httpx/openai/chromadb/sqlalchemy chatter as well.
LOG_LEVEL=INFO
